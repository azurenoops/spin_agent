# ──────────────────────────────────────────────────────────────
# ATO Copilot — Environment Configuration
# Copy to .env and fill in values.  Never commit this file with real secrets.
# ──────────────────────────────────────────────────────────────

# ── Stack ports ───────────────────────────────────────────────
# SQL Server host port
SQL_PORT=1433
# MCP Server host port
ATO_SERVER_PORT=3001
# Chat App host port
CHAT_PORT=5001
# React Dashboard host port
DASHBOARD_PORT=5173
# Redis host port
REDIS_PORT=6379

# ── SQL Server SA password ────────────────────────────────────
# Min 8 chars, mixed case, digit, symbol (SQL Server complexity requirement)
SQL_SA_PASSWORD=YourStrongP@ssw0rd!

# ── Run mode ──────────────────────────────────────────────────
# stdio | http  (http for docker-compose; stdio for MCP client direct)
ATO_RUN_MODE=http

# ── ASP.NET environment ───────────────────────────────────────
# Development: enables CAC simulation mode + relaxed policies
# Production:  enforces real auth, disables simulation
ASPNETCORE_ENVIRONMENT=Development

# ── Deployment mode (Feature 048) ────────────────────────────
# SingleTenant | MultiTenant
ATO_DEPLOYMENT__MODE=MultiTenant

# ── Azure AD / Entra ID ───────────────────────────────────────
ATO_AZUREAD__TENANTID=your-aad-tenant-id
ATO_AZUREAD__CLIENTID=your-app-registration-client-id
ATO_AZUREAD__CLIENTSECRET=your-app-registration-client-secret
# AzureCloud | AzureUSGovernment
ATO_AZUREAD__CLOUDENVIRONMENT=AzureUSGovernment

# ── Authentication (Feature 051) ─────────────────────────────
# Cac | Msal
ATO_AUTH__DEFAULTMETHOD=Cac
# AzureCloud | AzureUSGovernment
ATO_AUTH__CLOUD=AzureUSGovernment
# Idle timeout in minutes — FedRAMP maximum is 15
ATO_AUTH__IDLETIMEOUTMINUTES=14
# Cookie lifetime for remember-tenant (days)
ATO_AUTH__REMEMBERTENANTCOOKIEDAYS=30
# HMAC signing key for session cookies — generate with: openssl rand -base64 32
ATO_AUTH__COOKIE__SIGNINGKEY=replace-with-32-plus-random-base64-bytes

# MSAL config (used when ATO_AUTH__DEFAULTMETHOD=Msal)
ATO_AUTH__MSAL__CLIENTID=your-spa-msal-client-id
ATO_AUTH__MSAL__AUTHORITY=https://login.microsoftonline.us/your-tenant-id
ATO_AUTH__MSAL__REDIRECTURI=http://localhost:5173/login/callback
ATO_AUTH__MSAL__POSTLOGOUTREDIRECTURI=http://localhost:5173/login

# Role-claim mappings (property-name form; '.' in keys breaks docker-compose interpolation)
ATO_AUTH__ROLECLAIMMAPPINGS__CSPADMIN=CSP.Admin
ATO_AUTH__ROLECLAIMMAPPINGS__SOCANALYST=Auth.SocAnalyst

# Branding (all optional — fallback to "ATO Copilot" / no logo)
ATO_AUTH__BRANDING__DEPLOYMENTNAME=
ATO_AUTH__BRANDING__LOGOURL=
ATO_AUTH__BRANDING__SUPPORTEMAIL=

# ── Azure Subscription / Gateway ─────────────────────────────
ATO_GATEWAY__AZURE__TENANTID=your-azure-tenant-id
ATO_GATEWAY__AZURE__SUBSCRIPTIONID=your-subscription-id
# AzureGovernment | AzurePublicCloud
ATO_GATEWAY__AZURE__CLOUDENVIRONMENT=AzureGovernment
# true = use Managed Identity; false = use ClientId/Secret
ATO_GATEWAY__AZURE__USEMANAGEDIDENTITY=true
# Required when UseManagedIdentity=false:
# ATO_GATEWAY__AZURE__CLIENTID=
# ATO_GATEWAY__AZURE__CLIENTSECRET=

# ── Managed Identity authority (Azure Government) ────────────
AZURE_AUTHORITY_HOST=https://login.microsoftonline.us/

# ── Azure AI (Feature AI) ─────────────────────────────────────
ATO_AZUREAI__ENABLED=false
# OpenAi | AzureOpenAi
ATO_AZUREAI__PROVIDER=OpenAi
ATO_AZUREAI__ENDPOINT=
ATO_AZUREAI__DEPLOYMENTNAME=gpt-4o
ATO_AZUREAI__APIKEY=
ATO_AZUREAI__USEMANAGEDIDENTITY=true
# AzurePublicCloud | AzureUSGovernment
ATO_AZUREAI__CLOUDENVIRONMENT=AzurePublicCloud
ATO_AZUREAI__MAXTOOLITERATIONS=10
ATO_AZUREAI__TEMPERATURE=0.3
ATO_AZUREAI__FOUNDRYPROJECTENDPOINT=
ATO_AZUREAI__RUNTIMEOUTSECONDS=60

# ── Feature flags ─────────────────────────────────────────────
# Entra ID discovery dialog in the Dashboard
ATO_FEATURES__ENTRAIDDISCOVERYENABLED=true

# ── Compliance agent defaults ─────────────────────────────────
ATO_AGENTS__COMPLIANCE__DEFAULT_FRAMEWORK=NIST800-53
ATO_AGENTS__COMPLIANCE__DEFAULT_IMPACT_LEVEL=Moderate
ATO_AGENTS__COMPLIANCE__ENABLE_AUTOMATED_REMEDIATION=false

# ── Chat App ──────────────────────────────────────────────────
# Internal MCP Server URL (overridden in docker-compose to use internal DNS)
# ATO_MCPSERVER__BASEURL=http://localhost:3001
